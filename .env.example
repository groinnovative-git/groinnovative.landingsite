# ── EmailJS Configuration ──────────────────────────────────────────
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_AUTOREPLY=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# ── SEO Domain Configuration ──────────────────────────────────────
# The final production domain (used for canonical, OG, sitemap, schema URLs)
VITE_SITE_URL=https://groinnovative.com

# Set to "testing" on Vercel preview deployments to add noindex meta tag.
# Set to "production" when the final .com domain is live and ready for indexing.
VITE_SEO_ENV=production
